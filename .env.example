# EduGo API Mobile New - Environment Variables
# Copy this file to .env and fill in the values

# Application
APP_ENV=local

# Server
SERVER_PORT=8080
SERVER_HOST=0.0.0.0

# PostgreSQL
DATABASE_POSTGRES_HOST=localhost
DATABASE_POSTGRES_PORT=5432
DATABASE_POSTGRES_USER=edugo
DATABASE_POSTGRES_PASSWORD=your_password_here
DATABASE_POSTGRES_DATABASE=edugo
DATABASE_POSTGRES_SSLMODE=disable

# MongoDB
DATABASE_MONGODB_URI=mongodb://edugo:password@localhost:27017/edugo?authSource=admin
DATABASE_MONGODB_DATABASE=edugo

# RabbitMQ
MESSAGING_RABBITMQ_URL=amqp://edugo:password@localhost:5672/

# S3 Storage
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=edugo-materials
STORAGE_S3_ACCESS_KEY_ID=your_access_key
STORAGE_S3_SECRET_ACCESS_KEY=your_secret_key

# Auth
AUTH_JWT_SECRET=your_jwt_secret_here
AUTH_API_ADMIN_BASE_URL=http://localhost:8081

# Logging
LOGGING_LEVEL=debug
LOGGING_FORMAT=text
